# Notion Integration Secret (https://www.notion.so/profile/integrations 에서 발급)
NOTION_API_KEY=ntn_xxx

# 노션 데이터소스 ID (이미 만들어진 5개 DB, 하이픈 포함 UUID)
NOTION_EMPLOYEES_DATA_SOURCE_ID=b16bea16-587d-4fd2-86a3-d09f1848ec44
NOTION_VENDORS_DATA_SOURCE_ID=a09705e1-bc4d-431f-b5f7-9c1f5ceb5863
NOTION_PRODUCTS_DATA_SOURCE_ID=9b11a6c2-f883-4679-9e6e-1c5fa07f9068
NOTION_ORDER_REQUESTS_DATA_SOURCE_ID=5713bbaf-9f70-4750-9052-5fbdd41e3ef2
NOTION_DAILY_ORDERS_DATA_SOURCE_ID=1f1c81dd-e051-4acb-a293-e33f50dcf08f

# 세션 JWT 서명 키 (아무 랜덤 문자열, 32자 이상 권장)
# 생성 예: openssl rand -base64 32
SESSION_SECRET=change-this-to-a-random-secret

# CraftMyPDF (발주서 PDF 생성)
CRAFTMYPDF_API_KEY=your-craftmypdf-api-key
CRAFTMYPDF_TEMPLATE_ID=your-craftmypdf-template-id

# 자동화 엔진 API 보호용 시크릿 (Make.com에서 이 값을 Authorization: Bearer 헤더로 보내야 함)
# 생성 예: openssl rand -base64 24
CRON_SECRET=change-this-to-a-random-secret

# 컨펌/발송 채널 연동 (Phase 5)
APP_BASE_URL=https://order-app-deploy-ashen.vercel.app

# Gmail SMTP (John에게 컨펌/오류 알림 + 이메일 채널 거래처 발송)
GMAIL_USER=your-gmail@gmail.com
GMAIL_APP_PASSWORD=your-gmail-app-password
JOHN_NOTIFY_EMAIL=your-gmail@gmail.com

# 알리고 SMS (문자 채널 거래처 발송, 카카오톡 채널도 당분간 문자로 대체)
ALIGO_API_KEY=your-aligo-api-key
ALIGO_USER_ID=your-aligo-user-id
ALIGO_SENDER=사전등록된-발신번호
