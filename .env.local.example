# Notion Integration Secret (https://www.notion.so/profile/integrations 에서 발급)
NOTION_API_KEY=ntn_xxx

# 노션 데이터소스 ID (이미 만들어진 5개 DB, 하이픈 포함 UUID)
NOTION_EMPLOYEES_DATA_SOURCE_ID=b16bea16-587d-4fd2-86a3-d09f1848ec44
NOTION_VENDORS_DATA_SOURCE_ID=a09705e1-bc4d-431f-b5f7-9c1f5ceb5863
NOTION_PRODUCTS_DATA_SOURCE_ID=9b11a6c2-f883-4679-9e6e-1c5fa07f9068
NOTION_ORDER_REQUESTS_DATA_SOURCE_ID=5713bbaf-9f70-4750-9052-5fbdd41e3ef2
NOTION_DAILY_ORDERS_DATA_SOURCE_ID=1f1c81dd-e051-4acb-a293-e33f50dcf08f

# 세션 JWT 서명 키 (아무 랜덤 문자열, 32자 이상 권장)
# 생성 예: openssl rand -base64 32
SESSION_SECRET=change-this-to-a-random-secret
